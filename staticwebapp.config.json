{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/*.{css,js,json,ico,png,jpg,jpeg,gif,svg,webp,avif,woff,woff2,ttf,eot}"
    ]
  },
  "routes": [
    {
